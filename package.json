{
  "name": "tail-vapor",
  "version": "2.0.0",
  "description": "A vaporwave/synthwave/cyberpunk 80s retro Tailwind CSS theme with neon glows, grid backgrounds, and 8 customizable color variations",
  "main": "src/index.js",
  "files": [
    "src/"
  ],
  "keywords": [
    "tailwindcss",
    "tailwind",
    "vaporwave",
    "synthwave",
    "cyberpunk",
    "retro",
    "80s",
    "neon",
    "glow",
    "theme",
    "css"
  ],
  "author": "ianlintner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ianlintner/tail_vapor.git"
  },
  "peerDependencies": {
    "tailwindcss": ">=3.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "tailwindcss": "^3.4.0"
  },
  "scripts": {
    "build:demo": "npx tailwindcss -i ./src/styles.css -o ./demo/output.css --watch",
    "build": "npx tailwindcss -i ./src/styles.css -o ./demo/output.css",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  }
}
